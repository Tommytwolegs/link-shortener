{
  "manifest_version": 3,
  "name": "Link Shortener",
  "short_name": "Link Shortener",
  "version": "1.3.4",
  "description": "Cleans long Amazon, Agoda, Booking.com, Expedia, and Airbnb URLs — automatic address bar + one-click short-link toolbar.",
  "author": "Thomas Powers",
  "homepage_url": "https://github.com/Tommytwolegs/link-shortener",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "webNavigation",
    "storage"
  ],
  "action": {
    "default_title": "Link Shortener",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.amazon.co.uk/*",
    "*://*.amazon.ca/*",
    "*://*.amazon.de/*",
    "*://*.amazon.fr/*",
    "*://*.amazon.it/*",
    "*://*.amazon.es/*",
    "*://*.amazon.nl/*",
    "*://*.amazon.se/*",
    "*://*.amazon.pl/*",
    "*://*.amazon.com.tr/*",
    "*://*.amazon.com.au/*",
    "*://*.amazon.co.jp/*",
    "*://*.amazon.in/*",
    "*://*.amazon.sg/*",
    "*://*.amazon.ae/*",
    "*://*.amazon.sa/*",
    "*://*.amazon.eg/*",
    "*://*.amazon.com.mx/*",
    "*://*.amazon.com.br/*",
    "*://*.amazon.com.be/*",
    "*://*.agoda.com/*",
    "*://*.booking.com/*",
    "*://*.expedia.com/*",
    "*://*.expedia.co.uk/*",
    "*://*.expedia.ca/*",
    "*://*.expedia.com.au/*",
    "*://*.expedia.de/*",
    "*://*.expedia.fr/*",
    "*://*.expedia.it/*",
    "*://*.expedia.es/*",
    "*://*.expedia.nl/*",
    "*://*.expedia.com.mx/*",
    "*://*.expedia.com.br/*",
    "*://*.expedia.co.jp/*",
    "*://*.expedia.com.sg/*",
    "*://*.expedia.co.in/*",
    "*://*.airbnb.com/*",
    "*://*.airbnb.co.uk/*",
    "*://*.airbnb.ca/*",
    "*://*.airbnb.com.au/*",
    "*://*.airbnb.de/*",
    "*://*.airbnb.fr/*",
    "*://*.airbnb.it/*",
    "*://*.airbnb.es/*",
    "*://*.airbnb.nl/*",
    "*://*.airbnb.com.mx/*",
    "*://*.airbnb.com.br/*",
    "*://*.airbnb.co.jp/*",
    "*://*.airbnb.com.sg/*",
    "*://*.airbnb.co.in/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.amazon.co.uk/*",
        "*://*.amazon.ca/*",
        "*://*.amazon.de/*",
        "*://*.amazon.fr/*",
        "*://*.amazon.it/*",
        "*://*.amazon.es/*",
        "*://*.amazon.nl/*",
        "*://*.amazon.se/*",
        "*://*.amazon.pl/*",
        "*://*.amazon.com.tr/*",
        "*://*.amazon.com.au/*",
        "*://*.amazon.co.jp/*",
        "*://*.amazon.in/*",
        "*://*.amazon.sg/*",
        "*://*.amazon.ae/*",
        "*://*.amazon.sa/*",
        "*://*.amazon.eg/*",
        "*://*.amazon.com.mx/*",
        "*://*.amazon.com.br/*",
        "*://*.amazon.com.be/*"
      ],
      "js": [
        "src/asin.js",
        "src/content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "*://*.agoda.com/*"
      ],
      "js": [
        "src/site-toolbar.js",
        "src/agoda.js",
        "src/agoda-content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "*://*.booking.com/*"
      ],
      "js": [
        "src/site-toolbar.js",
        "src/booking.js",
        "src/booking-content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "*://*.expedia.com/*",
        "*://*.expedia.co.uk/*",
        "*://*.expedia.ca/*",
        "*://*.expedia.com.au/*",
        "*://*.expedia.de/*",
        "*://*.expedia.fr/*",
        "*://*.expedia.it/*",
        "*://*.expedia.es/*",
        "*://*.expedia.nl/*",
        "*://*.expedia.com.mx/*",
        "*://*.expedia.com.br/*",
        "*://*.expedia.co.jp/*",
        "*://*.expedia.com.sg/*",
        "*://*.expedia.co.in/*"
      ],
      "js": [
        "src/site-toolbar.js",
        "src/expedia.js",
        "src/expedia-content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "*://*.airbnb.com/*",
        "*://*.airbnb.co.uk/*",
        "*://*.airbnb.ca/*",
        "*://*.airbnb.com.au/*",
        "*://*.airbnb.de/*",
        "*://*.airbnb.fr/*",
        "*://*.airbnb.it/*",
        "*://*.airbnb.es/*",
        "*://*.airbnb.nl/*",
        "*://*.airbnb.com.mx/*",
        "*://*.airbnb.com.br/*",
        "*://*.airbnb.co.jp/*",
        "*://*.airbnb.com.sg/*",
        "*://*.airbnb.co.in/*"
      ],
      "js": [
        "src/site-toolbar.js",
        "src/airbnb.js",
        "src/airbnb-content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "minimum_chrome_version": "102"
}
